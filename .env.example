OPENAI_API_KEY=sk-...
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
GITHUB_REPO_OWNER=your-username
GITHUB_REPO_NAME=sdlc-demo-output
LLM_MODEL=openai:gpt-4o-mini
LOG_LEVEL=INFO
# Context7 MCP — authoritative doc source for code generation + review.
# API key is optional (public libraries work without one).
CONTEXT7_API_KEY=ctx...
# Toggle off to skip Context7 and fall back to empty docs_context.
USE_CONTEXT7=true
# How the stdio MCP server is launched. Defaults run Upstash's server via npx.
CONTEXT7_MCP_COMMAND=npx
CONTEXT7_MCP_ARGS=["-y", "@upstash/context7-mcp"]
