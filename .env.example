OPENAI_API_KEY=OPENAI_API_KEY

# ---- Embeddings / re-ranking ----
VOYAGE_API_KEY=pa-...             # Voyage AI for voyage-code-3 / voyage-3-large
COHERE_API_KEY=...                # Cohere for rerank-v3

# ---- Vector DB (Qdrant) ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                   # empty for local dev

# ---- Checkpoint store (Postgres) ----
POSTGRES_URL=postgresql://sdlc:sdlc@localhost:5432/sdlc_agents

# ---- Redis (cache + streams) ----
REDIS_URL=redis://localhost:6379/0

# ---- LangSmith (optional but recommended) ----
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=sdlc-agents-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---- MCP servers ----
# Bearer tokens for hosted MCP servers; referenced by name in configs/mcp_servers.yaml
MCP_GITHUB_TOKEN=ghp_...
MCP_FILESYSTEM_TOKEN=
MCP_CODE_EXEC_TOKEN=
MCP_DEPLOY_TOKEN=

# ---- App config ----
SDLC_ENV=dev                      # dev | staging | prod
SDLC_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
SDLC_CHECKPOINTER=sqlite          # sqlite | postgres
SDLC_DEFAULT_MODEL=claude-sonnet-4-5
SDLC_CHEAP_MODEL=claude-haiku-4-5  # for summaries, query expansion

# ---- Retrieval tuning ----
RETRIEVAL_TOP_K=5
RETRIEVAL_INITIAL_K=20            # before rerank
RETRIEVAL_MAX_CONTEXT_TOKENS=4000
RETRIEVAL_CACHE_TTL_SECONDS=3600
